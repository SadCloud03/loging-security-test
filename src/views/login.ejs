<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Login - My App</title>
    <style>
        .actions { margin-top: 15px; }
        .register-link { margin-top: 20px; display: block; font-size: 0.9em; }
    </style>
</head>
<body>
    <h1>Login Page</h1>
    <form id="loginForm">
        <input type="email" id="loginEmail" placeholder="user email" required><br>
        <input type="password" id="loginPassword" placeholder="user password" required><br>
        
        <div class="actions">
            <button type="button" class="login-btn" data-type="cookie">Cookie Login</button>
            <button type="button" class="login-btn" data-type="jwt">JWT Login</button>
        </div>
    </form>

    <div class="register-link">
        <p>Don't have an account? <a href="/register">Register here</a></p>
    </div>
    <script src="/js/login.js"></script>
</body>
</html>